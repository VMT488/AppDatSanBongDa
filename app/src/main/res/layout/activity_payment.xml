<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THÔNG TIN THANH TOÁN"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            android:textColor="#2E7D32"/>

        <TextView android:id="@+id/txtPayTenSan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="16sp" android:text="Sân: " android:textStyle="bold"/>
        <TextView android:id="@+id/txtPayNgayCa" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="16sp" android:text="Thời gian: " android:layout_marginTop="5dp"/>
        <TextView android:id="@+id/txtPayTongTien" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="18sp" android:text="Tổng tiền: " android:textColor="#E53935" android:textStyle="bold" android:layout_marginTop="5dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#D3D3D3" android:layout_marginVertical="15dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chọn phương thức thanh toán:" android:textStyle="bold" android:textSize="16sp"/>

        <RadioGroup
            android:id="@+id/radioGroupPayment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <RadioButton
                android:id="@+id/radQR"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thanh toán qua mã QR (Chuyển khoản)"
                android:checked="true"
                android:textSize="15sp"/>

            <RadioButton
                android:id="@+id/radTienMat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thanh toán tiền mặt tại quầy"
                android:textSize="15sp"/>
        </RadioGroup>

        <LinearLayout
            android:id="@+id/layoutQR"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="15dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vui lòng quét mã QR dưới đây để chuyển khoản"
                android:textColor="#757575"
                android:textSize="13sp"/>

            <ImageView
                android:id="@+id/imgQR"
                android:layout_width="250dp"
                android:layout_height="250dp"
                android:layout_marginTop="10dp"
                android:src="@android:drawable/ic_menu_report_image"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnXacNhanThanhToan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="XÁC NHẬN ĐÃ THANH TOÁN"
            android:backgroundTint="#2E7D32"
            android:textColor="@android:color/white"
            android:layout_marginTop="25dp"/>

    </LinearLayout>
</ScrollView>